{
  "productName": "Synced",
  "version": "0.1.0",
  "identifier": "com.synced.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:9876",
    "frontendDist": "../backend/static"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' blob: ws://localhost:* wss://localhost:* http://localhost:* ws://* wss://* http://* https://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' blob: data:; media-src 'self' blob:; script-src 'self'"
    },
    "windows": [
      {
        "title": "Synced",
        "width": 960,
        "height": 700,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/synced-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "installerHooks": "./windows/hooks.nsh",
        "displayLanguageSelector": false,
        "headerImage": null,
        "sidebarImage": null
      }
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
