# GhostChat Configuration
# Copy this file to .env and fill in values as needed.

# ── TURN Server (optional) ────────────────────────────────────────────
# For zero-trust, self-host a TURN server (e.g., coturn).
# Without TURN, peers behind symmetric NAT may fail to connect directly.
# TURN_URL=turn:your-turn-server.example.com:3478
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-credential

# ── Debug ─────────────────────────────────────────────────────────────
# Set to 1 to enable the /api/debug endpoint (exposes room state)
# GHOSTCHAT_DEBUG=0

# ── Logging ───────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
